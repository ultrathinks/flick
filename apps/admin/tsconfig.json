{
  "extends": "@flick/typescript-config/nextjs.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "plugins": [{ "name": "next" }],
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
