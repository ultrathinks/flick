{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": [],
      "passThroughEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "CORS_ORIGIN",
        "NODE_ENV",
        "DAUTH_*",
        "S3_*"
      ]
    }
  }
}
